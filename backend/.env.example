# Copy this file to .env and adjust values. Never commit the real .env.

DATABASE_URL=sqlite+aiosqlite:///./data/app.db
SECRET_KEY=please-change-this-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Seed admin account created on first startup if it doesn't already exist.
ADMIN_EMAIL=admin@techkraft.io
ADMIN_PASSWORD=admin12345

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173
